{
	"luci-app-antiblock": {
		"description": "Grant UCI and RPC access to LuCI app AntiBlock",
		"read": {
			"file": {
				"/*": [
					"read"
				],
				"/etc/init.d/antiblock": [
					"exec"
				]
			},
			"uci": [
				"antiblock"
			]
		},
		"write": {
			"file": {
				"/*": [
					"write"
				]
			},
			"uci": [
				"antiblock"
			]
		}
	}
}
